{
  "name": "bilibili-history-save-analysis",
  "description": "保存并分析哔哩哔哩历史记录",
  "private": true,
  "version": "2.0.0",
  "license": "MIT",
  "author": "Bilibili History Plugin Contributors and derivative contributors",
  "homepage": "https://github.com/rmqg/bilibili-history-sync",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmqg/bilibili-history-sync.git"
  },
  "bugs": {
    "url": "https://github.com/rmqg/bilibili-history-sync/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "scripts": {
    "dev": "wxt --mode development",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build -b chrome",
    "build:chrome": "wxt build -b chrome",
    "build:edge": "wxt build -b edge",
    "build:safari": "wxt build -b safari",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip -b chrome",
    "zip:chrome": "wxt zip -b chrome",
    "zip:edge": "wxt zip -b edge",
    "zip:safari": "wxt zip -b safari",
    "zip:firefox": "wxt zip -b firefox --sources",
    "package:safari": "wxt build -b safari && bash scripts/create-safari-project.sh",
    "package:stores": "wxt zip -b chrome && wxt zip -b edge && wxt zip -b firefox --sources && wxt zip -b safari && node scripts/write-release-checksums.mjs",
    "release:package": "corepack pnpm release:check && corepack pnpm package:stores && corepack pnpm release:verify",
    "release:check": "tsc --noEmit && prettier --check . && wxt build -b chrome && wxt build -b edge && wxt build -b firefox && wxt build -b safari",
    "release:verify": "node scripts/verify-release.mjs",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "use-debounce": "^10.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "3",
    "typescript": "^5.8.3",
    "wxt": "^0.20.6"
  }
}
